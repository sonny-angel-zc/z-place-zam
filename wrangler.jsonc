{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "z-place-zam",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-12",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "BOARD",
        "class_name": "BoardDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BoardDurableObject"]
    }
  ]
}
